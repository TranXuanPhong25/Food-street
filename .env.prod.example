# Copy file này -> .env (cùng thư mục docker-compose.prod.yml). KHÔNG commit .env.
# docker compose tự nạp .env để thay ${...} trong compose file.

# Tên miền (hoặc IP) của server — FE chạy HTTPS tại https://PHX_HOST:WEB_PORT
PHX_HOST=app.example.com

# Cổng HTTPS của FE (chạy thẳng port này, không dùng 80/443).
WEB_PORT=3200

# Cấu hình TLS cho Caddy. Server nội bộ 10.x + cổng tuỳ ý ⇒ Let's Encrypt TỰ ĐỘNG
# (HTTP-01/TLS-ALPN) KHÔNG dùng được vì cần cổng 80/443 công khai. Chọn 1:
#   1) Tự ký (nhanh, trình duyệt cảnh báo):   CADDY_EXTRA_TLS=tls internal
#   2) Chứng chỉ sẵn có (mount vào /certs):    CADDY_EXTRA_TLS=tls /certs/fullchain.pem /certs/privkey.pem
#   3) Let's Encrypt qua DNS-01: cần build Caddy kèm plugin DNS + API token (xem README deploy)
CADDY_EXTRA_TLS=tls internal

# Sinh bằng: cd backend && mix phx.gen.secret  (hoặc: openssl rand -base64 64)
SECRET_KEY_BASE=thay-bang-chuoi-bi-mat-dai

# Thông tin PostgreSQL (chạy trong container db)
DB_USER=food_street
DB_PASS=doi-mat-khau-that-manh
DB_NAME=food_street_prod

# Cổng web (FE) publish ra host. Mặc định 80/443.
# Đổi nếu cổng bị chiếm, vd HTTPS_PORT=8443 -> truy cập https://<ip>:8443
HTTP_PORT=80
HTTPS_PORT=443
