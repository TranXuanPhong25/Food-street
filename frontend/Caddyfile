# Caddy serve frontend qua HTTPS thẳng trên cổng WEB_PORT (mặc định 3200) + proxy /api.
# KHÔNG dùng 80/443. Cổng đổi qua biến WEB_PORT (truyền từ docker-compose).
#
# {$DOMAIN}: tên miền HOẶC IP của server (từ .env).
# {$CADDY_EXTRA_TLS}:
#   - Chỉ có IP  -> "tls internal" => Caddy tự ký (HTTPS, trình duyệt cảnh báo).
#   - Có domain  -> để trống. LƯU Ý: Let's Encrypt tự động cần cổng 80/443 để
#     xác thực, nên với cổng tuỳ ý (3200) hãy dùng "tls internal" hoặc cung cấp
#     chứng chỉ riêng: tls /path/cert.pem /path/key.pem
{
	# Truy cập bằng IP → client không gửi SNI → coi SNI = {$DOMAIN} để chọn đúng cert.
	default_sni {$DOMAIN}
}

https://{$DOMAIN}:{$WEB_PORT:3200} {
	{$CADDY_EXTRA_TLS}
	encode zstd gzip

	root * /srv

	# Gọi API -> backend container (mạng nội bộ docker)
	handle /api/* {
		reverse_proxy backend:4003
	}

	# SPA fallback cho React Router
	handle {
		try_files {path} /index.html
		file_server
	}
}
