# Caddy serve frontend (HTTP thuần) trên cổng WEB_PORT (mặc định 3200) + proxy /api.
# TLS do nginx phía trước terminate (cert *.pancake.vn), nên ở đây KHÔNG bật TLS.
# Đổi cổng qua biến WEB_PORT (truyền từ docker-compose).
:{$WEB_PORT:3200} {
	encode zstd gzip

	root * /srv

	# Gọi API -> backend container (mạng nội bộ docker)
	handle /api/* {
		reverse_proxy backend:4003 {
			# nginx ngoài đã terminate TLS; báo Phoenix biết request gốc là HTTPS
			# để force_ssl (prod.exs) KHÔNG redirect 301 loop.
			header_up X-Forwarded-Proto https
		}
	}

	# SPA fallback cho React Router
	handle {
		try_files {path} /index.html
		file_server
	}
}
